<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/cart.css">
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
    <%- include('../includes/navigation.ejs') %>
    <main>
        <ul class="cart__item-list">
            <% products.forEach(p => { %>
                <li class="cart__item">
                    <h1><%= p.title %></h1>
                    <h2>Quantity: <%= p.cartItem.quantity %></h2>
                    <div class="cart__item-controls">
                        <form action="/cart" method="POST">
                            <input type="hidden" value="<%= p.id %>" name="productId">
                            <input type="hidden" value="/checkout" name="redirectPath">
                            <button class="btn" type="submit">+</button>
                        </form>
                        <form action="/cart-decrement-item" method="POST">
                            <input type="hidden" value="<%= p.id %>" name="productId">
                            <input type="hidden" value="/checkout" name="redirectPath">
                            <button class="btn danger" type="submit">-</button>
                        </form>
                    </div>
                </li>
            <% }) %>
        </ul>
        <div class="centered">
            <h2>Total: $<%= totalSum %></h2>
        </div>
        
        <div class="centered">
            <form action="/create-order" method="POST" class="product-form">
                <div class="form-control">
                    <label for="name">Full Name</label>
                    <input type="text" name="name" id="name" required>
                </div>
                <div class="form-control">
                    <label for="street">Street</label>
                    <input type="text" name="street" id="street" required>
                </div>
                <div class="form-control">
                    <label for="city">City</label>
                    <input type="text" name="city" id="city" required>
                </div>
                <div class="form-control">
                    <label for="state">State</label>
                    <input type="text" name="state" id="state" required>
                </div>
                <div class="form-control">
                    <label for="zip">Zip Code</label>
                    <input type="text" name="zip" id="zip" required>
                </div>
                <button class="btn" type="submit">Complete Order</button>
            </form>
        </div>
    </main>
    <%- include('../includes/end.ejs') %>
